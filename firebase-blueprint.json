{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique user ID." },
        "email": { "type": "string", "format": "email", "description": "User email address." },
        "displayName": { "type": "string", "description": "User display name." },
        "photoURL": { "type": "string", "format": "uri", "description": "User profile photo URL." },
        "role": { "type": "string", "enum": ["admin", "user"], "description": "User role." },
        "bio": { "type": "string", "description": "User biography." },
        "joinedAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." }
      },
      "required": ["uid", "email"]
    },
    "ContentItem": {
      "title": "ContentItem",
      "description": "Learning material item.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique item ID." },
        "userId": { "type": "string", "description": "Owner user ID." },
        "title": { "type": "string", "description": "Title of the content." },
        "description": { "type": "string", "description": "Brief description." },
        "type": { "type": "string", "enum": ["pdf", "notes", "video", "practice"], "description": "Type of content." },
        "progress": { "type": "number", "description": "Learning progress (0-100)." },
        "tag": { "type": "string", "description": "Optional tag." },
        "activeSync": { "type": "boolean", "description": "Whether sync is active." },
        "fullContent": { "type": "string", "description": "The actual text content for AI processing." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["id", "userId", "title", "type", "progress"]
    },
    "StudySession": {
      "title": "StudySession",
      "description": "An interactive study session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique session ID." },
        "userId": { "type": "string", "description": "Student user ID." },
        "contentId": { "type": "string", "description": "Reference to the content item." },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["teacher", "student"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "evaluation": { "type": "object", "description": "Final session evaluation." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Session start timestamp." }
      },
      "required": ["id", "userId", "contentId"]
    },
    "GeneralChat": {
      "title": "GeneralChat",
      "description": "General assistant chat session.",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "Unique chat ID." },
        "userId": { "type": "string", "description": "User ID." },
        "title": { "type": "string", "description": "Optional title for the chat." },
        "messages": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "role": { "type": "string", "enum": ["teacher", "student"] },
              "text": { "type": "string" },
              "timestamp": { "type": "string", "format": "date-time" }
            }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last message timestamp." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Chat start timestamp." }
      },
      "required": ["id", "userId"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profiles."
    },
    "/content/{contentId}": {
      "schema": "ContentItem",
      "description": "Learning materials."
    },
    "/sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "Study session history."
    },
    "/general_chats/{chatId}": {
      "schema": "GeneralChat",
      "description": "General assistant chat history."
    }
  }
}
